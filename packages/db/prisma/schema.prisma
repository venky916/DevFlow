// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum ProjectRole {
  LEAD
  DEVELOPER
  VIEWER
}

enum IssueStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum IssuePriority {
  NO_PRIORITY
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum IssueType {
  BUG
  FEATURE
  TASK
  IMPROVEMENT
  OTHER
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum NotificationType {
  ISSUE_ASSIGNED
  ISSUE_COMMENTED
  SPRINT_STARTED
  SPRINT_COMPLETED
  WORKSPACE_INVITED
  PROJECT_ADDED
  MENTION
  OTHER
}

enum ActivityScope{
  ISSUE
  PROJECT
}


model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  email       String   @unique
  name        String?
  avatarUrl   String?
  timezone    String   @default("UTC")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaces   WorkspaceMember[]
  projects     ProjectMember[]
  comments     Comment[]
  activities   ActivityLog[]
  notifications Notification[]
  attachments  Attachment[] 
  createdIssues Issue[] @relation("createdIssues")
  assignedIssues Issue[] @relation("assignedIssues")
  sentInvites WorkspaceInvite[] @relation("sentInvites")

  @@map("users")
}


model Workspace{
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  projects     Project[]
  invites      WorkspaceInvite[]

  @@map("workspaces")
}

model WorkspaceInvite {
  id  String     @id @default(cuid())
  workspaceId  String
  email        String
  role         WorkspaceRole @default(DEVELOPER)
  token        String   @unique @default(uuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  invitedBy   String

  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  inviter     User      @relation("sentInvites",fields: [invitedBy], references: [id])

  @@map("workspace_invites")

}
model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(DEVELOPER)
  joinedAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("workspace_members")
  @@unique([workspaceId, userId])
}


model Project{
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  color       String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  members     ProjectMember[]
  sprints      Sprint[]
  issues        Issue[]
  activities   ActivityLog[]
  labels     Label[]

  @@map("projects")
}

model ProjectMember {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  role        ProjectRole @default(DEVELOPER)
  joinedAt   DateTime @default(now())


  project     Project   @relation(fields: [projectId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}


model Sprint{
  id          String   @id @default(cuid())
  name        String
  projectId   String
  status      SprintStatus @default(PLANNED)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project   @relation(fields: [projectId], references: [id])
  issues        Issue[]

  @@map("sprints")
}


model Issue{
  id          String   @id @default(cuid())
  title       String
  description String?
  status      IssueStatus @default(BACKLOG)
  priority    IssuePriority @default(NO_PRIORITY)
  type        IssueType     @default(TASK)
  position    String        @default("a0")
  dueDate     DateTime?
  parentId    String?
  sprintId    String?
  projectId   String
  assigneeId  String?
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent Issue? @relation("SubIssues", fields: [parentId], references: [id])
  children Issue[] @relation("SubIssues")

  comments    Comment[]
  attachments Attachment[]
  activities   ActivityLog[]
  labels      IssueLabel[]

  sprint      Sprint?   @relation(fields: [sprintId], references: [id])
  project     Project   @relation(fields: [projectId], references: [id])
  creator     User      @relation("createdIssues",fields: [creatorId], references: [id])
  assignee    User?     @relation("assignedIssues",fields: [assigneeId], references: [id])
  @@map("issues")
}

model Label{
  id          String   @id @default(cuid())
  name        String
  color       String
  projectId   String
  createdAt   DateTime @default(now())

  project     Project   @relation(fields: [projectId], references: [id])
  issues      IssueLabel[]

  @@unique([name, projectId])
  @@map("labels")
}


model IssueLabel {
  issueId     String
  labelId     String

  issue       Issue     @relation(fields: [issueId], references: [id],onDelete: Cascade)
  label       Label     @relation(fields: [labelId], references: [id],onDelete: Cascade)

  @@id([issueId, labelId])
  @@map("issue_labels")
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  issueId     String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  issue      Issue     @relation(fields: [issueId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  attachments Attachment[]

  @@map("comments")
}

model ActivityLog{
  id          String   @id @default(cuid())
  action      String
  scope       ActivityScope
  meta        Json?
  userId      String
  issueId     String?
  projectId   String
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  project     Project   @relation(fields: [projectId], references: [id])
  issue      Issue?   @relation(fields: [issueId], references: [id])

  @@map("activity_logs")
}



model Attachment {
  id          String   @id @default(cuid())
  url         String
  fileKey     String  
  fileName    String   
  fileSize    Int?     
  mimeType    String?  
  issueId     String?
  commentId   String?
  uploadedBy  String
  createdAt   DateTime @default(now())

  issue      Issue?     @relation(fields: [issueId], references: [id])
  comment    Comment?  @relation(fields: [commentId], references: [id])
  uploader   User      @relation(fields: [uploadedBy], references: [id])

  @@map("attachments")
}

model Notification {
  id          String   @id @default(cuid())
  content     String
  type       NotificationType
  link       String?
  isRead    Boolean  @default(false)
  triggeredBy String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])

  @@map("notifications")
}
